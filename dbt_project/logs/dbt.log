  create  table "flights_db"."analytics_marts"."mart_route_performance__dbt_tmp"
  
  
    as
  
  (
    WITH base AS (
    SELECT * FROM "flights_db"."analytics_intermediate"."int_flight_delays"
)

SELECT
    origin_airport,
    dest_airport,
    route_type,
    COUNT(*)                                      AS total_flights,
    ROUND(AVG(departure_delay_min)::numeric, 2)   AS avg_dep_delay_min,
    ROUND(AVG(arrival_delay_min)::numeric, 2)     AS avg_arr_delay_min,
    ROUND(AVG(elapsed_time_min)::numeric, 2)      AS avg_flight_duration_min,
    ROUND(AVG(distance_miles)::numeric, 2)        AS avg_distance_miles,
    SUM(is_cancelled)                             AS total_cancelled,
    ROUND(100.0 * SUM(is_cancelled)
        / COUNT(*)::numeric, 2)                   AS cancellation_rate_pct
FROM base
GROUP BY 1, 2, 3
HAVING COUNT(*) > 10
ORDER BY total_flights DESC
  );
  
[0m22:45:27.441230 [debug] [Thread-2 (]: On model.flight_pipeline.mart_airline_performance: /* {"app": "dbt", "dbt_version": "1.8.0", "profile_name": "flight_pipeline", "target_name": "dev", "node_id": "model.flight_pipeline.mart_airline_performance"} */

  
    

  create  table "flights_db"."analytics_marts"."mart_airline_performance__dbt_tmp"
  
  
    as
  
  (
    WITH base AS (
    SELECT * FROM "flights_db"."analytics_intermediate"."int_flight_delays"
)

SELECT
    DATE_TRUNC('month', flight_date)::date       AS month,
    airline_code,
    COUNT(*)                                      AS total_flights,
    SUM(is_cancelled)                             AS total_cancelled,
    SUM(CASE WHEN is_severely_delayed 
        THEN 1 ELSE 0 END)                        AS severely_delayed_flights,
    ROUND(AVG(departure_delay_min)::numeric, 2)   AS avg_dep_delay_min,
    ROUND(AVG(arrival_delay_min)::numeric, 2)     AS avg_arr_delay_min,
    ROUND(100.0 * SUM(is_cancelled)
        / COUNT(*)::numeric, 2)                   AS cancellation_rate_pct,
    ROUND(100.0 * SUM(
        CASE WHEN flight_status = 'On Time'
        THEN 1 ELSE 0 END)
        / COUNT(*)::numeric, 2)                   AS on_time_rate_pct
FROM base
GROUP BY 1, 2
ORDER BY 1, 3 DESC
  );
  
[0m22:45:27.441456 [debug] [Thread-1 (]: On model.flight_pipeline.mart_airport_summary: /* {"app": "dbt", "dbt_version": "1.8.0", "profile_name": "flight_pipeline", "target_name": "dev", "node_id": "model.flight_pipeline.mart_airport_summary"} */

  
    

  create  table "flights_db"."analytics_marts"."mart_airport_summary__dbt_tmp"
  
  
    as
  
  (
    WITH departures AS (
    SELECT
        origin_airport                               AS airport,
        COUNT(*)                                     AS total_departures,
        ROUND(AVG(departure_delay_min)::numeric, 2)  AS avg_dep_delay_min,
        SUM(is_cancelled)                            AS total_cancelled
    FROM "flights_db"."analytics_intermediate"."int_flight_delays"
    GROUP BY 1
),

arrivals AS (
    SELECT
        dest_airport                                 AS airport,
        COUNT(*)                                     AS total_arrivals,
        ROUND(AVG(arrival_delay_min)::numeric, 2)    AS avg_arr_delay_min
    FROM "flights_db"."analytics_intermediate"."int_flight_delays"
    GROUP BY 1
)

SELECT
    d.airport,
    d.total_departures,
    a.total_arrivals,
    d.total_departures + a.total_arrivals            AS total_operations,
    d.avg_dep_delay_min,
    a.avg_arr_delay_min,
    d.total_cancelled,
    ROUND(100.0 * d.total_cancelled
        / d.total_departures::numeric, 2)            AS cancellation_rate_pct
FROM departures d
JOIN arrivals a ON d.airport = a.airport
ORDER BY total_operations DESC
  );
  
